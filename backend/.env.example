APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# MySQL (php artisan db:create creates DB_DATABASE on the server):
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=shipping_management
# DB_USERNAME=root
# DB_PASSWORD=

# FedEx: stub (offline/tests) or rest (OAuth + Ship + Track). Default in config is rest; use stub in PHPUnit.
#
# --- Required for live FedEx tracking (legacy /api/*/shipments and Ship API) ---
# Without ALL of the following, creates use StubFedExClient (FX-STUB-* numbers, fedex_response.mode=stub):
#   FEDEX_MODE=rest
#   FEDEX_CLIENT_ID, FEDEX_CLIENT_SECRET, FEDEX_ACCOUNT_NUMBER
# After editing .env: php artisan config:clear
#
# FEDEX_MODE=rest
# FEDEX_MODE=stub
# Ship + Track share the same OAuth client. FEDEX_ACCOUNT_NUMBER is required for Ship API create.
# Prefer FEDEX_API_URL; FEDEX_BASE_URL is still supported as fallback.
# Same OAuth + Ship paths on both hosts: /oauth/token, POST /ship/v1/shipments, POST /location/v1/locations (Location Search), etc.
# Sandbox:   https://apis-sandbox.fedex.com
# Note: Address Validation API does not work reliably in sandbox (VIRTUAL.RESPONSE). Set FEDEX_ENV=production for real address validation.
# When FEDEX_ENV=sandbox, POST /api/user/profile/verify-address does not call FedEx (same as other sandbox address checks).
# Production: https://apis.fedex.com
# FEDEX_ENV=sandbox
# When FEDEX_ENV=sandbox, Ship create posts FedEx’s fixed virtualized sample body (label/tracking); your shipment still stores real addresses. Address Validation and packages/validate are skipped in that mode.
# FEDEX_API_URL=https://apis-sandbox.fedex.com
# Production example:
# FEDEX_ENV=production
# FEDEX_API_URL=https://apis.fedex.com
# FEDEX_BASE_URL=https://apis.fedex.com
# FEDEX_CLIENT_ID=
# FEDEX_CLIENT_SECRET=
# OAuth POST /oauth/token: client_credentials (default) | csp_credentials | client_pc_credentials
# FEDEX_OAUTH_GRANT_TYPE=client_credentials
# Optional for Integrator / Compatible / Parent-Child (FedEx child_Key / child_secret):
# FEDEX_CHILD_KEY=
# FEDEX_CHILD_SECRET=
# FEDEX_ACCOUNT_NUMBER=
# Sandbox only: skip Address Validation on ship create when VIRTUAL.RESPONSE blocks you (never enable against production host)
# FEDEX_SKIP_ADDRESS_VALIDATION_IN_SANDBOX=false
# Optional Y-m-d for Address Validation API inEffectAsOfTimestamp on ship create / tag (empty = today). Matches FedEx doc examples tied to a date.
# FEDEX_ADDRESS_VALIDATION_IN_EFFECT_AS_OF=
# Ship pipeline: Address resolve (unless skipped) → POST /ship/v1/shipments/packages/validate → POST /ship/v1/shipments.
# API errors include fedex_operation (validate|create) for the step that failed. Logs include requested_shipment_snapshot for Postman replay.
# Dev only: skip packages/validate (lose preflight alerts; same requestedShipment used for create). Do not use in production.
# FEDEX_SKIP_SHIP_VALIDATE=false
# Rate API (POST /rate/v1/rates/quotes): used for service selection before Ship and for POST /api/fedex/rates/quotes (quotes UI).
# FEDEX_RATE_LOOKUP_ENABLED=true
# FEDEX_RATE_VERSION_MAJOR=1
# FEDEX_RATE_VERSION_MINOR=1
# FEDEX_RATE_VERSION_PATCH=1
# Optional JSON object for Rate API root rateRequestControlParameters (e.g. returnTransitTimes, rateSortOrder). Empty = omit.
# FEDEX_RATE_REQUEST_CONTROL_PARAMETERS=
# Optional comma-separated carrier codes on Rate request: FDXE,FDXG
# FEDEX_RATE_CARRIER_CODES=
# Optional comma-separated Rate API root processingOptions (not Ship create). e.g. INCLUDE_PICKUPRATES
# FEDEX_RATE_PROCESSING_OPTIONS=
# Comma-separated service preference when Rate returns multiple services (empty = built-in order)
# FEDEX_RATE_SERVICE_PREFERENCE=
# Legacy POST /api/customer/shipments and /api/admin/shipments map to FedEx using these defaults:
# FEDEX_DEFAULT_SERVICE_TYPE=FEDEX_GROUND
# Legacy admin/customer ship: HI/AK origins use this instead of Ground (invalid for many lanes). If INVALID.INPUT persists, try another express service your sandbox supports.
# FEDEX_NON_CONTIGUOUS_ORIGIN_SERVICE_TYPE=FEDEX_EXPRESS_SAVER
# HI/AK: scheduled pickup often fails in sandbox; drop-off avoids INVALID.INPUT for many accounts.
# FEDEX_NON_CONTIGUOUS_ORIGIN_PICKUP_TYPE=DROPOFF_AT_FEDEX_LOCATION
# FEDEX_DEFAULT_PACKAGING_TYPE=YOUR_PACKAGING
# FEDEX_DEFAULT_PICKUP_TYPE=USE_SCHEDULED_PICKUP
# FEDEX_DEFAULT_IS_RESIDENTIAL=false
# FEDEX_SHIP_LABEL_RESPONSE=URL_ONLY
# Ship create: SYNCHRONOUS_ONLY | ALLOW_ASYNCHRONOUS (FedEx Ship API)
# FEDEX_PROCESSING_OPTION_TYPE=ALLOW_ASYNCHRONOUS
# Comma-separated root processingOptions (e.g. INCLUDE_PICKUPRATES); empty = omit (recommended for sandbox domestic Ship)
# FEDEX_PROCESSING_OPTIONS=
# FEDEX_ONE_LABEL_AT_A_TIME=true
# Merged label PDF: LABELS_ONLY (default) = shipping label pages only — avoids letter PDF where label art looks
# rotated next to folding instructions. Use LABELS_AND_DOCS for those instruction pages.
# FEDEX_MERGE_LABEL_DOC_OPTION=LABELS_ONLY
# Optional: PAPER_4X6 (default), or e.g. PAPER_85X11_TOP_HALF_LABEL for letter stock.
# FEDEX_LABEL_STOCK_TYPE=PAPER_4X6
# Optional thermal/plain feed direction; try LEFT_EDGE_OF_TEXT_FIRST if the label still looks sideways.
# FEDEX_LABEL_PRINTING_ORIENTATION=
# After changing FedEx env vars: from the backend folder run: php artisan config:clear
# FEDEX_SHIP_VERSION_MAJOR=1
# FEDEX_SHIP_VERSION_MINOR=1
# FEDEX_SHIP_VERSION_PATCH=0
# FEDEX_HTTP_TIMEOUT=30
# cURL error 60 (SSL on Windows / proxy): set FEDEX_CAINFO_PATH to absolute path of cacert.pem (https://curl.se/ca/cacert.pem)
# FEDEX_CAINFO_PATH=
# Optional: FEDEX_HTTP_VERIFY_SSL=false on trusted local dev only (never production)
# FEDEX_TOKEN_CACHE_SECONDS=3500
# Async labels: run a queue worker (QUEUE_CONNECTION) so CheckAsyncShipmentJob can poll FedEx results.
# OAuth token cache key in app: fedex.oauth.access_token (shared across FedEx APIs)
#
# --- FedEx sandbox verification (manual / Postman; PHPUnit encodes Test A/B in FedExSandboxVerificationShipmentsTest) ---
# Test A (control): mainland TN→GA with FEDEX_DEFAULT_SERVICE_TYPE=FEDEX_GROUND — if POST /api/admin/shipments returns 201 against live sandbox, your integration path is sound.
# Test B (HI lane): HI→AZ; set FEDEX_NON_CONTIGUOUS_ORIGIN_SERVICE_TYPE=FEDEX_2_DAY (or EXPRESS_SAVER) and try again. If Test A succeeds but Test B still returns 422 INVALID.INPUT with the same credentials, contact FedEx Developer support: sandbox service eligibility or account restrictions for Hawaii outbound (not an app bug).
#
# --- FedEx Tracking Webhook (receiver URL for FDP Advanced Integrated Visibility) ---
# POST {APP_URL}/api/webhooks/fedex/tracking — same secret as FDP Security Token (25–100 chars, upper/lower/digit). HMAC-SHA256 hex of raw body in x-fedex-signature.
# HTTPS/TLS 1.2+ required in production. Optional: whitelist FedEx push IPs (see FedEx Tracking Webhook business rules).
# FEDEX_WEBHOOK_SECRET=
# FEDEX_WEBHOOK_ENABLED=true
# Comma-separated IPs; empty = allow any client IP (dev). Example FedEx doc IPs: 169.63.102.107,150.239.111.98,...
# FEDEX_WEBHOOK_ALLOWED_IPS=
#
# --- FedEx Freight LTL (add API to same FedEx Developer project; separate Freight account number) ---
# Docs: https://developer.fedex.com/api/en-us/catalog/ltl-freight/v1/docs.html
# FEDEX_FREIGHT_ACCOUNT_NUMBER=
# Toggle surfaces (default true for rate/ship/pickup; direct is Freight Direct–specific options in same endpoints per FedEx docs)
# FEDEX_FREIGHT_LTL_RATE_ENABLED=true
# FEDEX_FREIGHT_LTL_SHIP_ENABLED=true
# FEDEX_FREIGHT_LTL_PICKUP_ENABLED=true
# FEDEX_FREIGHT_LTL_DIRECT_ENABLED=false
# Optional path overrides if FedEx changes REST routes (defaults match Freight LTL v1 catalog)
# FEDEX_FREIGHT_LTL_PATH_RATE_QUOTES=/rate/v1/freight/rates/quotes
# FEDEX_FREIGHT_LTL_PATH_SHIPMENTS=/ltl-freight/v1/shipments
# FEDEX_FREIGHT_LTL_PATH_PICKUP_AVAILABILITY=/ltl-freight/v1/freight-ltl-pickups/availabilities
# FEDEX_FREIGHT_LTL_PATH_PICKUPS=/ltl-freight/v1/freight-ltl-pickups
# FEDEX_FREIGHT_LTL_PATH_PICKUP_CANCEL=/ltl-freight/v1/freight-ltl-pickups/cancel

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
